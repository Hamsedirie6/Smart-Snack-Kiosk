{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=smartsnackkiosk.db"
  },
  "JwtSettings": {
    "Key": "REPLACE_WITH_SECURE_SECRET_KEY_MIN_32_CHARACTERS",
    "Issuer": "SmartSnackKiosk",
    "Audience": "SmartSnackKioskUsers",
    "ExpiryMinutes": 60
  },
  "AdminSettings": {
    "Username": "REPLACE_WITH_ADMIN_USERNAME",
    "Password": "REPLACE_WITH_ADMIN_PASSWORD"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
